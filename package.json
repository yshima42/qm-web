{
  "name": "quitmate",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "prepare": "husky",
    "dev:web:local": "turbo run dev:local --filter=web",
    "dev:web:dev": "turbo run dev:dev --filter=web",
    "dev:web:prod": "turbo run dev:prod --filter=web",
    "dev:lp": "turbo run dev --filter=lp",
    "build:lp": "turbo run build --filter=lp",
    "format": "prettier --write './apps/**/**/*.{js,ts,tsx,scss}'"
  },
  "resolutions": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.23.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-tailwindcss": "^3.17.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pinst": "^3.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.19",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
