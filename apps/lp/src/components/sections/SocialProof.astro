---
import { getTheme } from "@/config/themes";

type Stat = {
  value: string;
  label: string;
};

type Highlight = {
  quote: string;
  author: string;
  category: string;
};

type Props = {
  stats: Stat[];
  highlights?: Highlight[];
  activity?: string;
  namespace?: string;
};

const { stats, highlights = [], activity, namespace = "" } = Astro.props;
const theme = getTheme(namespace);
---

<section class="section-alt section-base">
  <div class="mx-auto max-w-6xl">
    <!-- 数字ハイライト -->
    <div class="stagger-children grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-8">
      {stats.map(({ value, label }) => (
        <div class="text-center">
          <div class="stat-number" style={`color: ${theme.accentColor}`}>
            {value}
          </div>
          <div class="mt-1 text-sm text-[var(--sub-foreground)]">
            {label}
          </div>
        </div>
      ))}
    </div>

    <!-- アクティビティ -->
    {activity && (
      <p class="animate-on-scroll mt-8 text-center text-sm text-[var(--sub-foreground)]">
        {activity}
      </p>
    )}

    <!-- レビューハイライト引用 -->
    {highlights.length > 0 && (
      <div class="mt-14 grid gap-6 md:mt-20 md:grid-cols-2 md:gap-10">
        {highlights.map(({ quote, author, category }) => (
          <div class="animate-on-scroll">
            <div class="text-4xl leading-none opacity-15" style={`color: ${theme.accentColor}`}>
              &ldquo;
            </div>
            <p class="mt-1 text-lg font-medium leading-relaxed text-[var(--foreground)] md:text-xl">
              {quote}
            </p>
            <p class="mt-4 text-sm text-[var(--sub-foreground)]">
              — {author}・{category}
            </p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
