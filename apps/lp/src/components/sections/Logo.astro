---
import { LOGO_ICONS, NAMESPACE_TO_PATH } from "@/config/themes";
import { useTranslations } from "@/i18n/utils";
import type { Locale } from "@/i18n/config";

type Props = {
  locale: Locale;
  namespace?: string;
  xl?: boolean;
  lightText?: boolean;
};

const { locale, namespace = "", xl = false, lightText = false } = Astro.props;
const t = useTranslations(locale, namespace || undefined);

const size = xl ? 56 : 42;
const fontStyle = xl ? "text-4xl" : "text-[28px]";
const iconSrc = LOGO_ICONS[namespace] ?? LOGO_ICONS[""];
// common.title から "|" の前の部分をサイト名として使用し、括弧の補足を除去
const fullTitle = t("common.title");
const beforePipe = fullTitle.includes("|") ? fullTitle.split("|")[0].trim() : fullTitle;
const siteName = beforePipe.replace(/[（(].+?[）)]/g, "").trim();
const basePath = NAMESPACE_TO_PATH[namespace] ?? "";
const href = `/${locale}${basePath}/`;
const textColor = lightText ? "text-white" : "text-gray-900";
---

<a href={href} class={`inline-flex items-center ${lightText ? "text-white" : ""}`} data-logo-link>
  <div class="inline-flex items-center gap-2" style={`min-height: ${size}px`}>
    <span class="flex shrink-0 items-center justify-center" style={`width: ${size}px; height: ${size}px`}>
      <img src={iconSrc} alt={siteName} width={size} height={size} class="block" />
    </span>
    <span
      class={`${fontStyle} font-medium leading-[1.1] ${textColor} self-center`}
      style="font-weight: 550; font-family: 'Inter Variable', 'Noto Sans JP Variable', sans-serif;"
    >
      {siteName}
    </span>
  </div>
</a>

<script>
  document.querySelector("[data-logo-link]")?.addEventListener("click", (e) => {
    const link = e.currentTarget as HTMLAnchorElement;
    if (link.pathname === window.location.pathname) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });
</script>
