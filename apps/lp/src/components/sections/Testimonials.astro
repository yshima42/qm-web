---
import { getTheme } from "@/config/themes";

type Testimonial = {
  name: string;
  title: string;
  message: string;
};

type Props = {
  title: string;
  testimonials: Testimonial[];
  namespace?: string;
};

const { title, testimonials, namespace } = Astro.props;
const theme = getTheme(namespace);
---

<section class={`${theme.testimonialsBg} px-6 py-20 text-center`}>
  <h2 class={`mb-12 text-3xl font-semibold ${theme.titleColor} md:text-4xl`}>{title}</h2>
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-3">
    {testimonials.map((item) => (
      <div class={`h-full rounded-lg border-none text-left shadow-md ${theme.cardBg} p-6`}>
        <div class="mb-4 flex justify-center">
          {[...Array(5)].map(() => (
            <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <h3 class={`mb-2 text-lg font-semibold ${theme.titleColor}`}>{item.title}</h3>
        <p class={`mb-4 text-sm ${theme.descColor}`}>&quot;{item.message}&quot;</p>
        <p class={`text-right text-sm font-semibold ${theme.descColor}`}>— {item.name}</p>
      </div>
    ))}
  </div>
</section>
