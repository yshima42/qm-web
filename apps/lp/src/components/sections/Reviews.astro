---
import { getTheme } from "@/config/themes";
import StoreBadges from "./StoreBadges.astro";

type Review = {
  name: string;
  category: string;
  message: string;
};

type Props = {
  title: string;
  reviews: Review[];
  locale: string;
  namespace?: string;
};

const { title, reviews, locale, namespace = "" } = Astro.props;
const theme = getTheme(namespace);
---

<section class="section-alt section-base">
  <div class="mx-auto max-w-6xl">
    <h2 class="animate-on-scroll mb-12 text-center md:mb-16">
      {title}
    </h2>

    <!-- モバイル: 横スクロール / デスクトップ: 2x3グリッド -->
    <div class="reviews-scroll stagger-children -mx-[1.5rem] flex snap-x snap-mandatory gap-4 overflow-x-auto px-[calc(50vw-140px)] pb-4 md:mx-0 md:grid md:grid-cols-2 md:gap-6 md:overflow-visible md:px-0 md:pb-0 lg:grid-cols-3">
      {reviews.map(({ name, category, message }) => (
        <div class="card flex w-[280px] shrink-0 snap-center flex-col p-6 md:w-auto">
          {/* ★評価 */}
          <div class="mb-3 flex gap-0.5" role="img" aria-label="5 out of 5 stars">
            {[...Array(5)].map(() => (
              <svg class="size-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="mb-4 flex-1 text-sm leading-relaxed text-[var(--foreground)]">
            &ldquo;{message}&rdquo;
          </p>

          <p class="text-xs text-[var(--sub-foreground)]">
            {name}・{category}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA 再表示 -->
    <div class="animate-on-scroll mt-12 flex justify-center md:mt-16">
      <StoreBadges locale={locale} namespace={namespace} size="large" />
    </div>
  </div>
</section>

<style>
  .reviews-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .reviews-scroll::-webkit-scrollbar {
    display: none;
  }
</style>
