---
import { getTheme } from "@/config/themes";

type Props = {
  title: string;
  items: { text: string }[];
  closing: string;
  namespace?: string;
};

const { title, items, closing, namespace = "" } = Astro.props;
const theme = getTheme(namespace);
---

<section class={`relative ${theme.introBg} dot-grid px-4 py-20 md:px-8 md:py-28`}>
  <div class="relative z-10 mx-auto max-w-3xl">
    <h2 class={`animate-on-scroll mb-12 text-center text-2xl font-bold ${theme.titleColor} md:mb-16 md:text-3xl`}>
      {title}
    </h2>

    <div class="stagger-children flex flex-col gap-4 md:gap-5">
      {items.map(({ text }) => (
        <div class="glass-card card-hover-glow flex items-start gap-4 rounded-2xl px-6 py-5">
          <span class="mt-0.5 flex size-8 shrink-0 items-center justify-center rounded-full bg-red-50 text-red-400" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <path d="M8 12h8" />
            </svg>
          </span>
          <p class={`text-base leading-relaxed ${theme.descColor} md:text-lg`}>
            {text}
          </p>
        </div>
      ))}
    </div>

    <p class={`animate-on-scroll mt-12 text-center text-lg font-semibold ${theme.titleColor} md:mt-16 md:text-xl`}>
      {closing}
    </p>
  </div>
</section>
