---
import { type Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { getChapterNav, chapterUrl } from "@/utils/learn";

type Props = {
  bookSlug: string;
  locale: Locale;
  currentSlug: string;
};

const { bookSlug, locale, currentSlug } = Astro.props;
const t = useTranslations(locale);
const { prev, next } = await getChapterNav(locale, bookSlug, currentSlug);
---

<nav class="mt-6 grid grid-cols-1 gap-3 border-t border-gray-200 pt-6 sm:grid-cols-2" aria-label="Chapter navigation">
  {prev ? (
    <a
      href={chapterUrl(locale, bookSlug, prev)}
      class="group flex flex-col rounded-lg border border-gray-200 p-4 transition-all hover:border-primary-300 hover:bg-primary-50/30"
    >
      <span class="mb-1 flex items-center gap-1 text-xs text-gray-500 group-hover:text-primary-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        {t("learn.chapter.prev-chapter")}
      </span>
      <span class="text-[13px] text-gray-400">{t("learn.chapter.chapter-prefix")}{prev.data.chapter}{t("learn.chapter.chapter-suffix")}</span>
      <span class="mt-1 text-sm font-semibold text-gray-900 group-hover:text-primary-700">{prev.data.title}</span>
    </a>
  ) : <div />}

  {next ? (
    <a
      href={chapterUrl(locale, bookSlug, next)}
      class="group flex flex-col rounded-lg border border-gray-200 p-4 text-right transition-all hover:border-primary-300 hover:bg-primary-50/30"
    >
      <span class="mb-1 flex items-center justify-end gap-1 text-xs text-gray-500 group-hover:text-primary-600">
        {t("learn.chapter.next-chapter")}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </span>
      <span class="text-[13px] text-gray-400">{t("learn.chapter.chapter-prefix")}{next.data.chapter}{t("learn.chapter.chapter-suffix")}</span>
      <span class="mt-1 text-sm font-semibold text-gray-900 group-hover:text-primary-700">{next.data.title}</span>
    </a>
  ) : <div />}
</nav>
