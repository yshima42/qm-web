---
import { getCategoryChipClasses } from "@/utils/category";

type CategoryItem = { name: string; count: number };

interface Props {
  categories: CategoryItem[];
  totalCount: number;
  allLabel: string;
}

const { categories, totalCount, allLabel } = Astro.props;

const baseChip =
  "category-chip group inline-flex shrink-0 snap-start items-center gap-1.5 rounded-full border border-gray-200 bg-white px-3.5 py-1.5 text-sm font-medium text-gray-700 transition-colors hover:border-gray-300 hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-gray-400";
---

<nav
  class="relative mb-10 -mx-4 px-4 sm:mx-0 sm:px-0"
  aria-label={allLabel}
  data-blog-filter
>
  <div
    class="flex snap-x gap-2 overflow-x-auto pb-2 [&::-webkit-scrollbar]:hidden sm:flex-wrap sm:justify-center sm:overflow-visible sm:pb-0"
    style="scrollbar-width: none;"
  >
    <button
      type="button"
      data-category=""
      data-active="true"
      aria-pressed="true"
      class={`${baseChip} ${getCategoryChipClasses("")}`}
    >
      <span>{allLabel}</span>
      <span class="text-xs tabular-nums text-gray-400 transition-colors group-data-[active=true]:text-white/70">
        {totalCount}
      </span>
    </button>
    {categories.map((cat) => (
      <button
        type="button"
        data-category={cat.name}
        data-active="false"
        aria-pressed="false"
        class={`${baseChip} ${getCategoryChipClasses(cat.name)}`}
      >
        <span>{cat.name}</span>
        <span class="text-xs tabular-nums text-gray-400 transition-colors group-data-[active=true]:text-white/70">
          {cat.count}
        </span>
      </button>
    ))}
  </div>
</nav>

<script>
  function initBlogFilter() {
    const root = document.querySelector<HTMLElement>("[data-blog-filter]");
    if (!root) return;

    const chips = root.querySelectorAll<HTMLButtonElement>(".category-chip");
    const cards = document.querySelectorAll<HTMLElement>("[data-blog-card]");
    const emptyState = document.getElementById("blog-filter-empty");

    const validCategories = new Set(
      Array.from(chips).map((c) => c.dataset.category ?? "")
    );

    function apply(category: string, pushHash: boolean) {
      let visible = 0;
      cards.forEach((card) => {
        const match = category === "" || card.dataset.category === category;
        card.classList.toggle("hidden", !match);
        if (match) visible++;
      });

      chips.forEach((chip) => {
        const active = (chip.dataset.category ?? "") === category;
        chip.dataset.active = active ? "true" : "false";
        chip.setAttribute("aria-pressed", active ? "true" : "false");
      });

      if (emptyState) {
        emptyState.classList.toggle("hidden", visible !== 0);
      }

      if (pushHash) {
        if (category) {
          const encoded = encodeURIComponent(category);
          history.replaceState(null, "", `#category=${encoded}`);
        } else if (window.location.hash) {
          history.replaceState(null, "", window.location.pathname + window.location.search);
        }
      }
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        apply(chip.dataset.category ?? "", true);
      });
    });

    function readHash(): string {
      const hash = window.location.hash.replace(/^#/, "");
      if (!hash) return "";
      const params = new URLSearchParams(hash);
      return params.get("category") ?? "";
    }

    const initial = readHash();
    if (initial && validCategories.has(initial)) {
      apply(initial, false);
    }

    window.addEventListener("hashchange", () => {
      const next = readHash();
      apply(validCategories.has(next) ? next : "", false);
    });
  }

  initBlogFilter();
  document.addEventListener("astro:page-load", initBlogFilter);
</script>
