---
import { getTheme, NAMESPACE_TO_PATH } from "@/config/themes";
import { type Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

type Props = {
  locale: Locale;
  namespace?: string;
};

const { locale, namespace = "" } = Astro.props;
const theme = getTheme(namespace);
const t = useTranslations(locale, namespace || undefined);
const basePath = NAMESPACE_TO_PATH[namespace] ?? "";
const prefix = `/${locale}${basePath}`;
const fullTitle = t("common.title");
const beforePipe = fullTitle.includes("|") ? fullTitle.split("|")[0].trim() : fullTitle;
const siteName = beforePipe.replace(/[（(].+?[）)]/g, "").trim();
const currentYear = new Date().getFullYear();
---

<footer class={`border-t ${theme.footerBorder} ${theme.footerBg} text-base`}>
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 py-8">
    <!-- リンク -->
    <div class={`flex flex-wrap justify-center gap-6 ${theme.footerLinkColor}`}>
      <a href={`${prefix}/terms`} class={`text-sm transition-colors md:text-base ${theme.footerLinkColor}`}>
        {t("footer.links.terms")}
      </a>
      <a href={`${prefix}/privacy`} class={`text-sm transition-colors md:text-base ${theme.footerLinkColor}`}>
        {t("footer.links.privacy")}
      </a>
      <a href={`${prefix}/contact`} class={`text-sm transition-colors md:text-base ${theme.footerLinkColor}`}>
        {t("footer.links.contact")}
      </a>
    </div>

    <!-- ソーシャル（日本語のみ） -->
    {locale === "ja" && (
      <div class="mt-2 flex gap-4">
        <a href="https://x.com/QuitMate_JP" target="_blank" rel="noopener noreferrer" class={`transition-colors ${theme.footerSocial}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18" /><path d="m6 6 12 12" />
          </svg>
        </a>
        <a href="https://note.com/quitmate" target="_blank" rel="noopener noreferrer" class={`transition-colors ${theme.footerSocial}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9" /><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z" />
          </svg>
        </a>
      </div>
    )}

    <!-- コピーライト -->
    <div class={`mt-4 w-full border-t pt-4 text-center text-xs ${theme.footerBorder} ${theme.footerCopyright}`}>
      &copy; {currentYear} {siteName}. All rights reserved.
    </div>
  </div>
</footer>
