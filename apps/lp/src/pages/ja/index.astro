---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import SocialProof from "@/components/sections/SocialProof.astro";
import Features from "@/components/sections/Features.astro";
import HowItWorks from "@/components/sections/HowItWorks.astro";
import Reviews from "@/components/sections/Reviews.astro";
import FAQ from "@/components/sections/FAQ.astro";
import FinalCTA from "@/components/sections/FinalCTA.astro";
import { useTranslations } from "@/i18n/utils";

const locale = "ja";
const t = useTranslations(locale);
---

<BaseLayout title={t("common.title")} description={t("common.description")} locale={locale}>
  <Hero title={t("hero.title")} description={t("hero.description")} locale={locale} />
  <SocialProof
    stats={[
      { value: t("social-proof.stats.users.value"), label: t("social-proof.stats.users.label") },
      { value: t("social-proof.stats.stories.value"), label: t("social-proof.stats.stories.label") },
      { value: t("social-proof.stats.likes.value"), label: t("social-proof.stats.likes.label") },
      { value: t("social-proof.stats.rating.value"), label: t("social-proof.stats.rating.label") },
    ]}
    activity={t("social-proof.activity")}
    highlights={[
      {
        quote: t("social-proof.highlight1.quote"),
        author: t("social-proof.highlight1.author"),
        category: t("social-proof.highlight1.category"),
      },
      {
        quote: t("social-proof.highlight2.quote"),
        author: t("social-proof.highlight2.author"),
        category: t("social-proof.highlight2.category"),
      },
    ]}
  />
  <Features
    title={t("features.title")}
    features={[
      { title: t("features.feature1.title"), description: t("features.feature1.description"), icon: "users" },
      { title: t("features.feature2.title"), description: t("features.feature2.description"), icon: "shield" },
      { title: t("features.feature3.title"), description: t("features.feature3.description"), icon: "timer" },
    ]}
  />
  <HowItWorks
    title={t("how-it-works.title")}
    steps={[
      { title: t("how-it-works.step1.title"), description: t("how-it-works.step1.description") },
      { title: t("how-it-works.step2.title"), description: t("how-it-works.step2.description") },
      { title: t("how-it-works.step3.title"), description: t("how-it-works.step3.description") },
    ]}
  />
  <Reviews
    title={t("reviews.title")}
    locale={locale}
    reviews={[
      { name: t("reviews.review1.name"), category: t("reviews.review1.category"), message: t("reviews.review1.message") },
      { name: t("reviews.review2.name"), category: t("reviews.review2.category"), message: t("reviews.review2.message") },
      { name: t("reviews.review3.name"), category: t("reviews.review3.category"), message: t("reviews.review3.message") },
      { name: t("reviews.review4.name"), category: t("reviews.review4.category"), message: t("reviews.review4.message") },
      { name: t("reviews.review5.name"), category: t("reviews.review5.category"), message: t("reviews.review5.message") },
      { name: t("reviews.review6.name"), category: t("reviews.review6.category"), message: t("reviews.review6.message") },
    ]}
  />
  <FAQ
    title={t("faq.title")}
    items={[
      { question: t("faq.items.0.question"), answer: t("faq.items.0.answer") },
      { question: t("faq.items.1.question"), answer: t("faq.items.1.answer") },
      { question: t("faq.items.2.question"), answer: t("faq.items.2.answer") },
      { question: t("faq.items.3.question"), answer: t("faq.items.3.answer") },
    ]}
  />
  <FinalCTA title={t("final-cta.title")} description={t("final-cta.description")} locale={locale} />
</BaseLayout>
