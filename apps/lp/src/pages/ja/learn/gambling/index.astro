---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogAppPromo from "@/components/sections/BlogAppPromo.astro";
import { useTranslations } from "@/i18n/utils";
import {
  getAllChapters,
  groupByPhasePart,
  chapterUrl,
  getPhaseLabel,
  getPartLabel,
  UPCOMING_PHASES,
} from "@/utils/learn";

const locale = "ja";
const category = "gambling";
const t = useTranslations(locale);

const chapters = await getAllChapters(category, locale);
const grouped = groupByPhasePart(chapters);
const totalChapters = chapters.length;
---

<BaseLayout
  title={t(`learn.${category}.title`)}
  description={t(`learn.${category}.description`)}
  locale={locale}
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- パンくず -->
    <nav aria-label="パンくずリスト">
      <ol class="mb-6 flex items-center gap-1 text-sm text-gray-400">
        <li><a href={`/${locale}/`} class="transition-colors hover:text-gray-600">ホーム</a></li>
        <li class="mx-0.5">/</li>
        <li><a href={`/${locale}/learn`} class="transition-colors hover:text-gray-600">{t("learn.breadcrumb")}</a></li>
        <li class="mx-0.5">/</li>
        <li class="text-gray-600" aria-current="page">{t(`learn.${category}.short-name`)}</li>
      </ol>
    </nav>

    <!-- ヒーロー -->
    <header class="mb-10 border-b border-gray-200 pb-8">
      <h1 class="mb-3 text-3xl font-black leading-tight text-[#111] sm:text-4xl">
        {t(`learn.${category}.name`)}
      </h1>
      <p class="mb-5 text-lg text-gray-600">{t(`learn.${category}.tagline`)}</p>
      <p class="text-sm leading-relaxed text-gray-700">{t(`learn.${category}.intro`)}</p>

      <div class="mt-6 flex flex-wrap gap-2 text-xs">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-emerald-700 ring-1 ring-emerald-200">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
          {t(`learn.${category}.published-phases-label`)}・<strong class="font-bold">{totalChapters}</strong>{t(`learn.${category}.total-chapters-label`)}
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-50 px-3 py-1 text-gray-500 ring-1 ring-gray-200">
          {t(`learn.${category}.upcoming-phases-label`)}
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-50 px-3 py-1 text-gray-500 ring-1 ring-gray-200">
          {t(`learn.${category}.reading-time-label`)}: {t(`learn.${category}.reading-time-value`)}
        </span>
      </div>

      <!-- Phase 進捗通知 -->
      <aside class="mt-5 rounded-lg border border-blue-100 bg-blue-50/50 p-4">
        <p class="text-xs leading-relaxed text-blue-900 sm:text-sm">
          <span class="mr-1 font-semibold">📖</span>
          {t(`learn.${category}.phase-progress-notice`)}
        </p>
      </aside>
    </header>

    <!-- 使い方ガイド -->
    <section class="mb-12">
      <h2 class="mb-3 text-xl font-bold text-gray-900">
        {t(`learn.${category}.usage-guide-heading`)}
      </h2>
      <p class="mb-5 text-sm text-gray-600">{t(`learn.${category}.usage-guide-intro`)}</p>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <article class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="mb-2 text-sm font-bold text-gray-900">
            {t(`learn.${category}.usage-pattern-a-title`)}
          </h3>
          <p class="text-xs leading-relaxed text-gray-600">
            {t(`learn.${category}.usage-pattern-a-body`)}
          </p>
        </article>
        <article class="rounded-lg border border-amber-200 bg-amber-50/50 p-4">
          <h3 class="mb-2 text-sm font-bold text-amber-900">
            ⚠️ {t(`learn.${category}.usage-pattern-b-title`)}
          </h3>
          <p class="text-xs leading-relaxed text-amber-800">
            {t(`learn.${category}.usage-pattern-b-body`)}
          </p>
        </article>
        <article class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="mb-2 text-sm font-bold text-gray-900">
            {t(`learn.${category}.usage-pattern-c-title`)}
          </h3>
          <p class="text-xs leading-relaxed text-gray-600">
            {t(`learn.${category}.usage-pattern-c-body`)}
          </p>
        </article>
        <article class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="mb-2 text-sm font-bold text-gray-900">
            {t(`learn.${category}.usage-pattern-d-title`)}
          </h3>
          <p class="text-xs leading-relaxed text-gray-600">
            {t(`learn.${category}.usage-pattern-d-body`)}
          </p>
        </article>
      </div>
    </section>

    <!-- 目次 -->
    <section class="mb-12">
      <h2 class="mb-6 text-xl font-bold text-gray-900">
        {t(`learn.${category}.table-of-contents`)}
      </h2>

      <div class="space-y-8">
        {grouped.map((phase) => (
          <div>
            <h3 class="mb-4 text-base font-bold text-gray-900">
              {getPhaseLabel(phase.phase, locale)}
            </h3>
            <div class="space-y-5">
              {phase.parts.map((part) => (
                <div>
                  <h4 class="mb-2 text-sm font-semibold text-gray-700">
                    {getPartLabel(part.code, locale)}
                  </h4>
                  <ol class="space-y-1.5 border-l-2 border-gray-200 pl-4">
                    {part.chapters.map((chapter) => (
                      <li>
                        <a
                          href={chapterUrl(category, locale, chapter)}
                          class="group flex items-start gap-2 rounded py-1 text-sm text-gray-700 transition-colors hover:text-primary-700"
                        >
                          <span class="inline-block min-w-[1.75rem] text-xs font-medium text-gray-400">
                            {chapter.data.chapter}.
                          </span>
                          <span class="flex-1 group-hover:underline">{chapter.data.title}</span>
                          {chapter.data.required && (
                            <span class="inline-block flex-shrink-0 rounded-sm bg-amber-100 px-1.5 py-0.5 text-[10px] font-bold text-amber-700">
                              {t("learn.chapter.required-label")} ⚠️
                            </span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ol>
                </div>
              ))}
            </div>
          </div>
        ))}

        {/* Phase 2-5 プレースホルダ（執筆中） */}
        {UPCOMING_PHASES.map((phaseNum) => (
          <div class="opacity-60">
            <h3 class="mb-2 flex flex-wrap items-baseline gap-2 text-base font-bold text-gray-500">
              {getPhaseLabel(phaseNum, locale)}
              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-500">
                {t("learn.coming-soon")}
              </span>
            </h3>
          </div>
        ))}
      </div>
    </section>

    <!-- 注意書き -->
    <section class="mb-10 rounded-lg border border-gray-200 bg-gray-50 p-5">
      <h3 class="mb-2 text-sm font-bold text-gray-900">
        {t(`learn.${category}.disclaimer-heading`)}
      </h3>
      <p class="text-xs leading-relaxed text-gray-600">
        {t(`learn.${category}.disclaimer-body`)}
      </p>
    </section>

    <BlogAppPromo locale={locale} />
  </div>
</BaseLayout>
