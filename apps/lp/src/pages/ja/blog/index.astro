---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCategoryFilter from "@/components/pages/BlogCategoryFilter.astro";
import BlogPostCard from "@/components/sections/BlogPostCard.astro";
import { useTranslations } from "@/i18n/utils";
import { getAllPosts } from "@/utils/blog";
import { sortCategoriesByDefinedOrder } from "@/utils/category";

const locale = "ja";
const t = useTranslations(locale);
const posts = await getAllPosts(locale);

// カテゴリごとの記事数を集計（降順）
const categoryCountMap = new Map<string, number>();
for (const post of posts) {
  const cat = post.data.category;
  if (!cat) continue;
  categoryCountMap.set(cat, (categoryCountMap.get(cat) ?? 0) + 1);
}
const categories = sortCategoriesByDefinedOrder(
  Array.from(categoryCountMap.entries()).map(([name, count]) => ({ name, count })),
);
---

<BaseLayout title={t("blog.title")} description={t("blog.description")} locale={locale}>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <h1 class="mb-2 text-4xl font-bold text-gray-900">{t("blog.journal-title")}</h1>
      <p class="text-lg text-gray-600">{t("blog.journal-description")}</p>
    </div>

    {posts.length === 0 ? (
      <div class="py-20 text-center">
        <h2 class="mb-4 text-2xl font-semibold text-gray-700">{t("blog.no-posts")}</h2>
        <p class="text-gray-500">{t("blog.content-preparing")}</p>
      </div>
    ) : (
      <>
        {categories.length > 1 && (
          <BlogCategoryFilter
            categories={categories}
            totalCount={posts.length}
            allLabel={t("blog.filter-all")}
          />
        )}

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => <BlogPostCard post={post} locale={locale} filterable />)}
        </div>

        <div id="blog-filter-empty" class="hidden py-16 text-center">
          <p class="text-gray-500">{t("blog.filter-no-results")}</p>
        </div>
      </>
    )}
  </div>
</BaseLayout>
