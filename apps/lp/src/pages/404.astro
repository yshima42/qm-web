---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" locale="en" noHeaderFooter>
  <div class="flex min-h-screen flex-col items-center justify-center gap-4 p-8">
    <h1 class="text-6xl font-bold text-gray-300">404</h1>
    <p class="text-lg text-gray-600">Oops! This page doesn't exist.</p>
    <a href="/en/" class="mt-4 text-primary-600 hover:underline">Back to homepage</a>
  </div>
</BaseLayout>
