---
// ロケールなし /blog/ -> /en/blog/ へリダイレクト
const destination = "/en/blog/";
const canonicalUrl = `https://about.quitmate.app${destination}`;
---

<!doctype html>
<title>Redirecting to: {destination}</title>
<meta http-equiv="refresh" content={`0;url=${destination}`} />
<meta name="robots" content="noindex" />
<link rel="canonical" href={canonicalUrl} />
<body>
  <a href={destination}>Redirecting to {destination}</a>
</body>
